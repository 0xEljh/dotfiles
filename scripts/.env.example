# Notion API

NOTION_TIME_ACCOUNTANT_SECRET=secret_xxx

# --- Data source IDs ---
# Time Accounting database (aw_notion_sync, waka_notion_sync, sync_notion_bread)
NOTION_TIME_ACCOUNTING_DATASOURCE_ID=
# Bread/Tasks database (sync_notion_bread)
NOTION_BREAD_DATASOURCE_ID=

# notion-cat can also fall back to NOTION_TIME_ACCOUNTANT_SECRET
NOTION_TOKEN=secret_xxx
NOTION_CAT_DATA_SOURCE_ID=

# WakaTime

WAKATIME_API_KEY=waka_xxx

# ============================================================================
# ActivityWatch / Timezone
# ============================================================================

# Directory containing aw_*.json exports (default: ./aw-data)
# AW_DATA_DIR=./aw-data

# Timezone for defining "a day" in journals and AW aggregation
TARGET_TZ=Asia/Singapore

# Timezone for sync_notion_bread (defaults to America/New_York)
# CURRENT_TIMEZONE=America/New_York

# Hours into a new day to keep updating the previous day (default: 2)
# FREEZE_HOURS=2
