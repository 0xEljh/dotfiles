# Notion API

NOTION_TIME_ACCOUNTANT_SECRET=secret_xxx

# --- Data source IDs ---
# Time Accounting database (aw_notion_sync, waka_notion_sync, sync_notion_bread)
NOTION_TIME_ACCOUNTING_DATASOURCE_ID=
# Bread/Tasks database (sync_notion_bread)
NOTION_BREAD_DATASOURCE_ID=

# notion-cat can also fall back to NOTION_TIME_ACCOUNTANT_SECRET
NOTION_TOKEN=secret_xxx
NOTION_CAT_DATA_SOURCE_ID=

# Paper Inbox database (paper_inbox_sync; token falls back to
# NOTION_TIME_ACCOUNTANT_SECRET). Also read by the bot's weekly papers digest
# via the awEnvFile passthrough in telegram-bot.nix.
NOTION_PAPER_INBOX_DATASOURCE_ID=42902fc5-c254-4b7c-9d1d-244990a85e2f
# Optional paper_inbox_sync overrides (defaults shown):
# GARDEN_BRIDGE_DIR=~/.local/share/garden-bridge
# GARDEN_SERVE_DIR=~/digital-garden
# GARDEN_REMOTE=            # default: origin of GARDEN_SERVE_DIR
# GARDEN_SITE_URL=https://0xeljh.com

# WakaTime

WAKATIME_API_KEY=waka_xxx

# ============================================================================
# ActivityWatch / Timezone
# ============================================================================

# Directory containing aw_*.json exports (default: ./aw-data)
# AW_DATA_DIR=./aw-data

# Timezone for defining "a day" in journals and AW aggregation
TARGET_TZ=Asia/Singapore

# Timezone for sync_notion_bread (defaults to Asia/Singapore)
# CURRENT_TIMEZONE=Asia/Singapore

# Hours into a new day to keep updating the previous day (default: 2)
# FREEZE_HOURS=2
