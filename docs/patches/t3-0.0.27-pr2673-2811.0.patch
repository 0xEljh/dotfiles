... 276   const frontmatterMatch = content.match(/^\uFEFF?---\r?\n([\s\S]*?)\r?\n---[ \t]*(?:\r?\n|$)/);
... 277   if (!frontmatterMatch) {
... 278     return null;
... 279   }
... 280 
... 281   const frontmatter = frontmatterMatch[1]!.replace(/\r\n/g, "\n");
... 282   const name = readFrontmatterScalar(frontmatter, "name");
