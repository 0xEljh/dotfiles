... 229 function readFrontmatterScalar(frontmatter: string, key: string): string | undefined {
... 230   const lines = frontmatter.split("\n");
... 231   const keyPattern = new RegExp(`^${key}:\\s*(.*)$`);
... 232 
... 233   for (let i = 0; i < lines.length; i++) {
... 234     const match = lines[i]!.match(keyPattern);
... 235     if (!match) {
... 236       continue;
... 237     }
... 238 
... 239     const inline = match[1]!.trim();
... 240     const block = inline.match(/^([>|])[+-]?\s*(?:#.*)?$/);
... 241     if (!block) {
... 242       // Quoted values keep embedded `#`; only unquoted scalars get
... 243       // trailing-comment stripping.
... 244       const quoted = inline.match(/^(["'])([\s\S]*?)\1\s*(?:#.*)?$/);
... 245       return quoted ? quoted[2]!.trim() : inline.replace(/\s+#.*$/, "").trim();
... 246     }
... 247 
... 248     // Block scalar: collect the following more-indented lines.
... 249     const collected: Array<string> = [];
... 250     for (let j = i + 1; j < lines.length; j++) {
... 251       const line = lines[j]!;
... 252       if (line.trim().length === 0) {
... 253         collected.push("");
... 254         continue;
... 255       }
... 256       if (!/^[ \t]/.test(line)) {
... 257         break;
... 258       }
... 259       collected.push(line.trim());
... 260     }
... 261     while (collected.length > 0 && collected[collected.length - 1] === "") {
... 262       collected.pop();
... 263     }
... 264     return block[1] === "|"
... 265       ? collected.join("\n").trim()
... 266       : collected.join(" ").replace(/\s+/g, " ").trim();
... 267   }
... 268 
... 269   return undefined;
... 270 }
