{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium",
      "permission": {
        "parallel_*": "allow"
      }
    },
    "plan": {
      "permission": {
        "*": "allow"
      }
    }
  },
  "small_model": "opencode-go/kimi-k2.7-code",
  "permission": {
    "*": "allow",
    "arxiv_*": "deny",
    "exa_*": "deny",
    "parallel_*": "deny"
  },
  "plugin": [],
  "mcp": {
    "arxiv": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "arxiv-mcp-server[pdf]==0.5.0",
        "arxiv-mcp-server",
        "--storage-path",
        "{env:HOME}/.local/share/arxiv-mcp/papers"
      ],
      "environment": {
        "MAX_RESULTS": "50",
        "REQUEST_TIMEOUT": "60"
      },
      "enabled": true,
      "timeout": 60000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_MCP_API_KEY}"
      },
      "enabled": true,
      "timeout": 15000
    },
    "parallel": {
      "type": "remote",
      "url": "https://search.parallel.ai/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:PARALLEL_MCP_API_KEY}"
      },
      "enabled": true,
      "timeout": 15000
    }
  }
}
