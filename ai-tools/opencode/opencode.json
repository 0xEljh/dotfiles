{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "opencode-go/kimi-k2.7-code",
  "permission": {
    "*": "allow",
    "arxiv_*": "deny",
    "exa_*": "deny",
    "parallel_*": "deny"
  },
  "plugin": [],
  "agent": {
    "reviewer": {
      "description": "Reviews proposals, plans, and designs. This GLM-5.2 driven agent is intended for independent, deep reviews.",
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "edit": "deny",
        "task": {
          "*": "allow",
          "general": "deny",
          "reviewer*": "deny"
        }
      },
      "prompt": "Review the design document for design issues, overlooked considerations, blindspots. Flag alternatives that may not have been considered. Highlight logic errors too."
    },
    "reviewer-lite": {
      "description": "Reviews proposals, plans, and designs. This kimi-k2.7 driven agent is intended for independent, lightweight reviews: simpler, go-wide consistency and correctness checks.",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.7-code",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "edit": "deny",
        "task": {
          "*": "allow",
          "general": "deny",
          "reviewer*": "deny"
        }
      },
      "prompt": "Review the design document for design issues, overlooked considerations, blindspots. Flag alternatives that may not have been considered. Highlight logic errors too."
    },
    "reviewer-alt": {
      "description": "Reviews proposals, plans, and designs. This deepseek agent is intended for independent, small, scoped reviews. It might make errors.",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "edit": "deny",
        "task": {
          "*": "allow",
          "general": "deny",
          "reviewer*": "deny"
        }
      },
      "prompt": "Review the design document for design issues, overlooked considerations, blindspots. Flag alternatives that may not have been considered. Highlight logic errors too."
    }
  },
  "mcp": {
    "arxiv": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "arxiv-mcp-server[pdf]==0.5.0",
        "arxiv-mcp-server",
        "--storage-path",
        "{env:HOME}/.local/share/arxiv-mcp/papers"
      ],
      "environment": {
        "MAX_RESULTS": "50",
        "REQUEST_TIMEOUT": "60"
      },
      "enabled": true,
      "timeout": 60000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_MCP_API_KEY}"
      },
      "enabled": true,
      "timeout": 15000
    },
    "parallel": {
      "type": "remote",
      "url": "https://search.parallel.ai/mcp",
      "oauth": false,
      "enabled": true,
      "timeout": 15000
    }
  }
}
