{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "opencode-go/kimi-k2.7-code",
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "agent": {
    "reviewer": {
      "description": "Reviews proposals, plans, and designs. This GLM-5.2 driven agent is intended for independent (cross-model) review of current specs.",
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "edit": "deny",
        "task": {
          "*": "allow",
          "general": "deny",
          "reviewer*": "deny"
        }
      },
      "prompt": "Review the design document for design issues, overlooked considerations, blindspots. Flag alternatives that may not have been considered. Highlight logic errors too."
    }
  },
  "mcp": {
    "arxiv": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "arxiv-mcp-server[pdf]",
        "arxiv-mcp-server"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ],
      "enabled": true,
      "timeout": 60000
    }
  },
  "provider": {
    "google": {
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "capabilities": {
            "reasoning": true,
            "toolcall": true
          },
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high"
            }
          }
        }
      }
    }
  }
}
