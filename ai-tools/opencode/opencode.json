{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "opencode-go/kimi-k2.6",
  "plugin": ["opencode-gemini-auth@latest"],
  "provider": {
    "google": {
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "capabilities": {
            "reasoning": true,
            "toolcall": true
          },
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high"
            }
          }
        }
      }
    }
  }
}
